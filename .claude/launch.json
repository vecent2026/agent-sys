{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    },
    {
      "name": "admin-service",
      "runtimeExecutable": "mvn",
      "runtimeArgs": ["-f", "services/admin-service/pom.xml", "spring-boot:run"],
      "port": 8081
    },
    {
      "name": "user-service",
      "runtimeExecutable": "mvn",
      "runtimeArgs": ["-f", "services/user-service/pom.xml", "spring-boot:run"],
      "port": 8082
    },
    {
      "name": "log-service",
      "runtimeExecutable": "mvn",
      "runtimeArgs": ["-f", "services/log-service/pom.xml", "spring-boot:run"],
      "port": 8083
    }
  ]
}
